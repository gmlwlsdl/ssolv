{
  "expo": {
    "name": "Solv",
    "slug": "Solv",
    "scheme": "Solv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/solv-mobile-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "모두의 취향을 모아, 바로 추천받는 우리 모임의 식당",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.solv.app",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/solv-mobile-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.solv.app"
    },
    "web": {
      "favicon": "./assets/solv-mobile-icon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-apple-authentication",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [{ "name": "GoogleUtilities", "modular_headers": true }]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9110c694-2f9f-4c18-9acf-8799988c545a"
      }
    },
    "owner": "ssolv"
  }
}
